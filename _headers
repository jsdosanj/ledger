# Cloudflare Pages headers — low-risk security hardening.
# The Content-Security-Policy below is REPORT-ONLY: it does NOT block anything,
# it only reports violations. After verifying no legitimate requests are flagged
# (browser console / report endpoint), promote it to an enforcing
# `Content-Security-Policy` by renaming the header. Do NOT enforce yet.
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy-Report-Only: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: blob: https://img.clerk.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline' https://*.clerk.accounts.dev https://*.clerk.com https://clerk.dosanjhlabs.com https://challenges.cloudflare.com; worker-src 'self' blob:; connect-src 'self'; frame-src 'self' https://*.clerk.accounts.dev https://*.clerk.com https://clerk.dosanjhlabs.com https://challenges.cloudflare.com
  X-Robots-Tag: noai, noimageai
  Content-Usage: train-ai=n, search=y
  TDM-Reservation: 1
  TDM-Policy: https://ledger.dosanjhlabs.com/ai-policy.html
